<view class="container">
  <view class="header">
    <text class="title">选择录入模块</text>
    <text class="subtitle">同一张鞋盒标签图片，不同模块解析/写入字段不同</text>
  </view>

  <view class="cards">
    <view class="card" wx:for="{{modules}}" wx:key="key" bindtap="chooseModule" data-module="{{item.key}}">
      <text class="card-title">{{item.label}}</text>
      <text class="card-desc">{{item.desc}}</text>
    </view>
  </view>
</view>

