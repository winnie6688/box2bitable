.container {
  padding: 40rpx;
  background-color: #f7f8fa;
  min-height: 100vh;
}

.header {
  margin-bottom: 60rpx;
  text-align: center;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #1f2329;
  display: block;
}

.subtitle {
  font-size: 28rpx;
  color: #646a73;
  margin-top: 16rpx;
  display: block;
}

.upload-section {
  width: 100%;
  margin-bottom: 60rpx;
}

.upload-card {
  width: 100%;
  height: 400rpx;
  background: #f0f2f5;
  border: 4rpx dashed #3370FF;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  font-size: 36rpx;
  color: #3370FF;
  margin-bottom: 24rpx;
}

.preview-image {
  width: 100%;
  height: 300rpx;
}

.upload-tip {
  font-size: 28rpx;
  color: #8f959e;
}

.action-section {
  width: 100%;
}

.btn-primary {
  width: 100% !important;
  background: #3370FF;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0;
  font-size: 32rpx;
}
