<view class="container">
  <view class="header">
    <text class="title">库存查询</text>
    <text class="subtitle">输入货号，查询各尺码数量</text>
  </view>

  <view class="search">
    <input class="input" placeholder="请输入货号（如 3363-16）" value="{{itemNo}}" bindinput="onInput" />
    <button class="btn" loading="{{loading}}" disabled="{{loading}}" bindtap="submit">查询</button>
  </view>

  <view wx:if="{{hasResult}}" class="result">
    <view class="result-header">
      <text class="result-title">尺码 - 数量</text>
    </view>
    <view wx:for="{{rows}}" wx:key="size" class="row">
      <text class="cell size">{{item.size}}</text>
      <text class="cell qty">{{item.quantity}}</text>
    </view>
  </view>
</view>

