.container {
  padding: 30rpx;
  background-color: #f7f8fa;
  min-height: 100vh;
}

.header {
  margin-bottom: 24rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1f2329;
}

.subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #646a73;
}

.search {
  display: flex;
  gap: 16rpx;
  align-items: center;
  margin-bottom: 24rpx;
}

.input {
  flex: 1;
  height: 72rpx;
  background: #fff;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #1f2329;
}

.btn {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 28rpx;
  background: #3370FF;
  color: #fff;
  font-size: 28rpx;
}

.result {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.result-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1f2329;
}

.row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-top: 1rpx solid #f2f3f5;
}

.cell {
  font-size: 28rpx;
  color: #1f2329;
}

.qty {
  font-weight: bold;
}

