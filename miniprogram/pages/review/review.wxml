<view class="container">
  <view class="header">
    <text class="title">人工复核</text>
    <text class="subtitle">当前模块：{{moduleLabel}} · 识别到 {{results.length}} 条记录</text>
  </view>

  <scroll-view class="result-list" scroll-y>
    <block wx:if="{{module === 'purchase'}}">
      <view class="group-card" wx:for="{{purchaseGroups}}" wx:for-item="g" wx:key="groupKey">
        <view class="group-header">
          <text class="group-title">{{g.item_no}}</text>
          <text class="group-count">{{g.items.length}} 条</text>
        </view>

        <view class="group-form">
          <view class="form-item">
            <text class="label">货号</text>
            <input class="input" value="{{g.item_no}}" data-groupindex="{{index}}" data-field="item_no" bindinput="onPurchaseGroupInputChange" />
          </view>

          <view class="form-row">
            <view class="form-item half">
              <text class="label">供应商</text>
              <input class="input" value="{{g.supplier}}" data-groupindex="{{index}}" data-field="supplier" bindinput="onPurchaseGroupInputChange" />
            </view>
            <view class="form-item half">
              <text class="label">颜色</text>
              <input class="input" value="{{g.color}}" data-groupindex="{{index}}" data-field="color" bindinput="onPurchaseGroupInputChange" />
            </view>
          </view>

          <view class="form-item">
            <text class="label">品类（必填）</text>
            <picker mode="selector" range="{{categoryOptions}}" bindchange="onPurchaseCategoryChange" data-groupindex="{{index}}">
              <view class="picker">
                <text class="picker-text {{g.category ? '' : 'picker-placeholder'}}">{{g.category || '请选择'}}</text>
              </view>
            </picker>
          </view>
        </view>

        <view class="table">
          <view class="table-header">
            <text class="th th-size">尺码</text>
            <text class="th th-qty">数量</text>
            <text class="th th-status">状态</text>
            <text class="th th-actions">操作</text>
          </view>
          <view class="table-row" wx:for="{{g.items}}" wx:for-item="row" wx:key="_idx">
            <input class="cell input-cell" value="{{row.size}}" data-index="{{row._idx}}" data-field="size" bindinput="onInputChange" />
            <input class="cell input-cell" value="{{row.quantity}}" data-index="{{row._idx}}" data-field="quantity" bindinput="onInputChange" />
            <view class="cell status-cell">
              <text wx:if="{{row.sync_status}}" class="status-badge status-{{row.sync_status}}">
                {{row.sync_status === 'success' ? '已同步' : '失败'}}
              </text>
            </view>
            <view class="cell action-cell">
              <button class="btn-delete-mini" size="mini" bindtap="removeResult" data-index="{{row._idx}}">删除</button>
            </view>
          </view>
        </view>

        <view wx:for="{{g.items}}" wx:for-item="row" wx:key="_idx">
          <view wx:if="{{row.sync_status === 'failed' && row.sync_error}}" class="sync-error">
            <text class="sync-error-text">{{row.sync_error}}</text>
          </view>
        </view>
      </view>
    </block>

    <block wx:else>
    <view class="card" wx:for="{{results}}" wx:key="index">
      <view class="card-header">
        <text class="supplier-title">
          {{module === 'purchase' ? (item.supplier || '未知供应商') : (moduleLabel + '记录')}}
        </text>
        <view class="header-right">
          <text wx:if="{{item.sync_status}}" class="status-badge status-{{item.sync_status}}">
            {{item.sync_status === 'success' ? '已同步' : '同步失败'}}
          </text>
          <text class="tag">#{{index + 1}}</text>
        </view>
      </view>

      <view class="sku-line" wx:if="{{module !== 'sales'}}">
        <text class="sku-label">SKU_Code</text>
        <text class="sku-value">{{item.sku_code}}</text>
      </view>

      <view class="form-item" wx:if="{{module === 'purchase'}}">
        <text class="label">供应商</text>
        <input class="input" value="{{item.supplier}}" data-index="{{index}}" data-field="supplier" bindinput="onInputChange" />
      </view>
      
      <view class="form-item">
        <text class="label">货号</text>
        <input class="input" value="{{item.item_no}}" data-index="{{index}}" data-field="item_no" bindinput="onInputChange" />
      </view>

      <view class="form-row">
        <view class="form-item half">
          <text class="label">颜色</text>
          <input class="input" value="{{item.color}}" data-index="{{index}}" data-field="color" bindinput="onInputChange" />
        </view>
        <view class="form-item half">
          <text class="label">尺码</text>
          <input class="input" value="{{item.size}}" data-index="{{index}}" data-field="size" bindinput="onInputChange" />
        </view>
      </view>

      <view wx:if="{{module === 'sales'}}" class="form-row">
        <view class="form-item half">
          <text class="label">数量</text>
          <input class="input" value="{{item.quantity}}" data-index="{{index}}" data-field="quantity" bindinput="onInputChange" />
        </view>
        <view class="form-item half">
          <text class="label">金额（元）</text>
          <input class="input" value="{{item.amount}}" data-index="{{index}}" data-field="amount" bindinput="onInputChange" />
        </view>
      </view>

      <view wx:if="{{module === 'sales'}}" class="form-item">
        <text class="label">支付方式</text>
        <picker mode="selector" range="{{payOptions}}" bindchange="onPayMethodChange" data-index="{{index}}">
          <view class="picker">
            <text class="picker-text">{{item.pay_method || '请选择'}}</text>
          </view>
        </picker>
      </view>

      <view wx:if="{{module === 'sales'}}" class="form-item">
        <text class="label">备注</text>
        <input class="input" value="{{item.remark}}" data-index="{{index}}" data-field="remark" bindinput="onInputChange" />
      </view>

      <view class="card-footer">
        <button class="btn-delete" size="mini" bindtap="removeResult" data-index="{{index}}">删除此条</button>
      </view>

      <view wx:if="{{item.sync_status === 'failed' && item.sync_error}}" class="sync-error">
        <text class="sync-error-text">{{item.sync_error}}</text>
      </view>
    </view>
    </block>

    <view wx:if="{{hasFailures}}" class="failure-panel">
      <view class="failure-title">失败明细（{{failures.length}}）</view>
      <view class="failure-item" wx:for="{{failures}}" wx:key="index">
        <text class="failure-sku">{{item.item.item_no}}-{{item.item.color}}-{{item.item.size}}</text>
        <text class="failure-msg">{{item.error}}</text>
      </view>
    </view>
  </scroll-view>

  <view class="footer-actions">
    <button wx:if="{{!hasFailures}}" class="btn-primary" loading="{{syncing}}" bindtap="confirmSync">确认并同步到飞书</button>
    <button wx:else class="btn-retry" loading="{{syncing}}" bindtap="retrySync">部分同步失败，点击重试</button>
  </view>
</view>
