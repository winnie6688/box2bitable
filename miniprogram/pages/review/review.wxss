.container {
  padding: 30rpx;
  background-color: #f7f8fa;
  display: block;
}

.header {
  margin-bottom: 30rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1f2329;
}

.subtitle {
  font-size: 26rpx;
  color: #646a73;
  margin-top: 8rpx;
  display: block;
}

.result-list {
  height: calc(100vh - 300rpx);
  padding-bottom: 40rpx;
}

.card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.group-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.group-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 16rpx;
  border-bottom: 1rpx solid #f2f3f5;
  padding-bottom: 12rpx;
}

.group-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1f2329;
}

.group-count {
  font-size: 24rpx;
  color: #8f959e;
}

.group-form {
  margin-bottom: 16rpx;
}

.picker-placeholder {
  color: #8f959e;
}

.table {
  border-radius: 10rpx;
  overflow: hidden;
  border: 1rpx solid #f2f3f5;
}

.table-header {
  display: flex;
  background: #f7f8fa;
  padding: 14rpx 12rpx;
}

.th {
  font-size: 22rpx;
  color: #646a73;
}

.th-size {
  flex: 1;
}

.th-qty {
  flex: 1;
}

.th-status {
  width: 140rpx;
  text-align: center;
}

.th-actions {
  width: 140rpx;
  text-align: right;
}

.table-row {
  display: flex;
  align-items: center;
  padding: 12rpx;
  border-top: 1rpx solid #f2f3f5;
}

.cell {
  font-size: 26rpx;
  color: #1f2329;
}

.input-cell {
  flex: 1;
  height: 64rpx;
  background: #f5f6f7;
  border-radius: 8rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  color: #1f2329;
}

.status-cell {
  width: 140rpx;
  display: flex;
  justify-content: center;
}

.action-cell {
  width: 140rpx;
  display: flex;
  justify-content: flex-end;
}

.btn-delete-mini {
  color: #f54a45 !important;
  border: 1rpx solid #f54a45 !important;
  background: transparent !important;
  font-size: 24rpx !important;
}

.card-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
  border-bottom: 1rpx solid #f2f3f5;
  padding-bottom: 16rpx;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.supplier-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #3370FF;
}

.tag {
  font-size: 24rpx;
  color: #8f959e;
}

.status-badge {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1;
}

.status-success {
  background: rgba(52, 199, 89, 0.12);
  color: #2ea043;
}

.status-failed {
  background: rgba(245, 74, 69, 0.12);
  color: #f54a45;
}

.sku-line {
  display: flex;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.sku-label {
  font-size: 22rpx;
  color: #8f959e;
}

.sku-value {
  font-size: 22rpx;
  color: #1f2329;
}

.form-item {
  margin-bottom: 20rpx;
}

.form-row {
  display: flex;
  justify-content: space-between;
}

.form-item.half {
  width: 48%;
}

.label {
  font-size: 24rpx;
  color: #8f959e;
  margin-bottom: 8rpx;
  display: block;
}

.input {
  height: 72rpx;
  background: #f5f6f7;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #1f2329;
}

.picker {
  height: 72rpx;
  background: #f5f6f7;
  border-radius: 8rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
}

.picker-text {
  font-size: 28rpx;
  color: #1f2329;
}

.card-footer {
  text-align: right;
  margin-top: 10rpx;
}

.btn-delete {
  color: #f54a45 !important;
  border: 1rpx solid #f54a45 !important;
  background: transparent !important;
}

.sync-error {
  margin-top: 12rpx;
  background: rgba(245, 74, 69, 0.08);
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
}

.sync-error-text {
  color: #f54a45;
  font-size: 24rpx;
}

.failure-panel {
  margin-top: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
  margin-bottom: 40rpx;
}

.failure-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1f2329;
  margin-bottom: 16rpx;
}

.failure-item {
  padding: 14rpx 0;
  border-top: 1rpx solid #f2f3f5;
}

.failure-sku {
  display: block;
  font-size: 26rpx;
  color: #1f2329;
}

.failure-msg {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #f54a45;
}

.footer-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx;
  background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.05);
}

.btn-primary {
  width: 100% !important;
  background: #3370FF;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  color: #fff;
}

.btn-retry {
  width: 100% !important;
  background: #ff9d00;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  color: #fff;
}
